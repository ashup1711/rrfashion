// ─────────────────────────────────────────────────────────
//  RR FASHION — Prisma Schema (PostgreSQL)
//  Phase 1 Foundation: Full schema overhaul
//  Models: User, Category, Brand, Product, ProductVariant,
//          ProductImage, ProductTag, Review, StoreLocation,
//          Order, OrderItem, Cart, CartItem, InventoryUnit,
//          InventorySummary, InventoryLock, StockMovement,
//          AdminUser, RoleModel, Permission, RolePermission,
//          RefreshToken, AuditLog, SizeGuide
// ─────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════
//  ENUMS
// ══════════════════════════════════════════════════════════

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  PARTIALLY_CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentType {
  SALE_PAYMENT
  RENTAL_CHARGE
  SECURITY_DEPOSIT
  DEPOSIT_REFUND
  LATE_FEE
  DAMAGE_CHARGE
  REFUND
}

enum PaymentChannel {
  ONLINE
  OFFLINE
}

enum PaymentMethod {
  CARD
  UPI
  NETBANKING
  WALLET
  CASH
  POS_CARD
}

enum OrderChannel {
  ONLINE
  OFFLINE
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ImageSizeType {
  THUMBNAIL
  MEDIUM
  LARGE
  ORIGINAL
}

enum ImageVariantType {
  ORIGINAL
  MEDIUM
  THUMBNAIL
}

enum InventoryUnitStatus {
  AVAILABLE
  RESERVED
  RENTED_OUT
  SOLD
  DAMAGED
  IN_WASH
  UNDER_REPAIR
  LOST
}

enum InventoryLockStatus {
  ACTIVE
  RELEASED
  EXPIRED
}

enum ReportStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  MANUAL
  TRANSFER_IN
  TRANSFER_OUT
  LOCK
  UNLOCK
  RESERVATION
  SALE_FINAL
}

enum RentalBookingStatus {
  BOOKED
  IN_USE
  RETURNED
  INSPECTED
  CLOSED
  LATE_RETURN
  DAMAGE_ASSESSED
  UNDER_REPAIR
  CANCELLED
}

enum InvoiceType {
  INVOICE
  CREDIT_NOTE
  SUPPLEMENTARY_INVOICE
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CouponType {
  PERCENT
  FLAT
}

enum CouponAppliesTo {
  ALL
  SALE
  RENT
}

// ══════════════════════════════════════════════════════════
//  USER & AUTH
// ══════════════════════════════════════════════════════════

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  role            Role     @default(CUSTOMER)
  addresses       Json?
  isGuest         Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  deletedAt       DateTime?

  profilePhoto    String?  // URL of the user's profile photo
  profilePhotoKey String?  // Storage key for the profile photo (used for deletion/re-upload)

  orders         Order[]
  userAddresses  UserAddress[]
  reviews        Review[]
  cart           Cart?
  refreshTokens  RefreshToken[]
  wishlists      Wishlist[]
  notifications  Notification[]
  walletTransactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([deletedAt])
  @@map("users")
}

model UserAddress {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("Home")
  line1     String   @map("line1")
  line2     String?  @map("line2")
  city      String   @map("city")
  state     String   @map("state")
  pincode   String   @map("pincode")
  phone     String?  @map("phone")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, isDefault])
  @@map("user_addresses")
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUserId String?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  userAgent   String?
  isRevoked   Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([adminUserId])
  @@index([token])
  @@map("refresh_tokens")
}

// ══════════════════════════════════════════════════════════
//  OTP VERIFICATION
// ══════════════════════════════════════════════════════════

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  purpose   String
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@map("otp_verifications")
}

model ProcessedWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique @map("event_id")
  eventType String   @map("event_type")
  payload   Json     @map("payload")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@map("processed_webhook_events")
}

// ══════════════════════════════════════════════════════════
//  PRODUCT CATALOG — Category, Brand, Product, Variant, Image, Tag
// ══════════════════════════════════════════════════════════

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)

  brandId String?
  brand   Brand?   @relation(fields: [brandId], references: [id])

  parentId String?
  parent   Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products   Product[]
  sizeGuides SizeGuide[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([brandId])
  @@index([slug])
  @@map("categories")
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)

  products   Product[]
  categories Category[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brands")
}

model Product {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  description      String?
  basePrice        Decimal   @db.Decimal(12, 2)
  salePrice        Decimal?  @db.Decimal(12, 2)
  images           String[]
  stock            Int       @default(0)
  version          Int       @default(0)
  isFeatured       Boolean   @default(false)
  isActive         Boolean   @default(true)
  fabric           String?
  hsnCode          String?
  isRentable       Boolean   @default(false)
  isSellable       Boolean   @default(true)
  careInstructions String?
  sortPriority     Int       @default(0)
  deletedAt        DateTime?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  variants       ProductVariant[]
  tags           ProductTag[]
  reviews        Review[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  guestCartItems GuestCartItem[]
  inquiries      Inquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([isFeatured])
  @@index([slug])
  @@index([deletedAt])
  @@index([isActive, deletedAt, salePrice])
  @@map("products")
}

model ProductVariant {
  id               String    @id @default(uuid())
  productId        String
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  size             String
  color            String
  sku              String    @unique
  barcode          String?   @unique
  salePrice        Decimal?  @db.Decimal(12, 2)
  rentPricePerDay  Decimal?  @db.Decimal(12, 2)
  securityDeposit  Decimal?  @db.Decimal(12, 2)
  weightGrams      Int?
  isActive         Boolean   @default(true)
  deletedAt        DateTime?

  images             ProductImage[]
  inventoryUnits     InventoryUnit[]
  inventorySummaries InventorySummary[]
  inventoryLocks     InventoryLock[]
  stockMovements     StockMovement[]
  orderItems         OrderItem[]
  cartItems          CartItem[]
  guestCartItems     GuestCartItem[]
  reviews            Review[]
  wishlists          Wishlist[]
  guestWishlistItems GuestWishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
  @@index([deletedAt])
  @@map("product_variants")
}

model ProductImage {
  id            String            @id @default(uuid())
  variantId     String
  variant       ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url           String
  storageKey    String?           @map("storage_key")
  altText       String?
  sortOrder     Int               @default(0)
  width         Int?
  height        Int?
  fileSize      Int?              @map("file_size")
  mimeType      String?           @map("mime_type")
  variantType   ImageVariantType  @default(ORIGINAL) @map("variant_type")
  parentImageId String?           @map("parent_image_id")
  parentImage   ProductImage?     @relation("ImageVariants", fields: [parentImageId], references: [id], onDelete: Cascade)
  variants      ProductImage[]    @relation("ImageVariants")

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([storageKey])
  @@index([parentImageId])
  @@map("product_images")
}

model ProductTag {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String
  value     String

  @@unique([productId, key, value])
  @@map("product_tags")
}

model SizeGuide {
  id               String   @id @default(uuid())
  categoryId       String
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  measurementsJson Json?
  imageUrl         String?
  createdAt        DateTime @default(now())

  @@index([categoryId])
  @@map("size_guides")
}

// ══════════════════════════════════════════════════════════
//  REVIEWS
// ══════════════════════════════════════════════════════════

model Review {
  id        String       @id @default(uuid())
  rating    Int
  comment   String?
  photos    String[]
  status    ReviewStatus @default(PENDING)

  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  guestSessionId  String?       @map("guest_session_id")
  guestSession    GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)

  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  orderItemId String?    @map("order_item_id")
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  reviewedByAdminId String?
  reviewedBy        AdminUser? @relation(fields: [reviewedByAdminId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([guestSessionId])
  @@index([productId])
  @@index([variantId])
  @@index([orderItemId])
  @@unique([userId, productId])
  @@index([status])
  @@map("reviews")
}

// ══════════════════════════════════════════════════════════
//  STORE LOCATION
// ══════════════════════════════════════════════════════════

model StoreLocation {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String?
  state     String
  pincode   String?
  gstin     String
  phone     String?
  isActive  Boolean  @default(true)

  orders             Order[]
  invoices           Invoice[]
  inventoryUnits     InventoryUnit[]
  inventorySummaries InventorySummary[]
  inventoryLocks     InventoryLock[]
  stockMovements     StockMovement[]
  rentalBookings     RentalBooking[]

  createdAt DateTime @default(now())

  @@map("store_locations")
}

// ══════════════════════════════════════════════════════════
//  ORDER & CART
// ══════════════════════════════════════════════════════════

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestSessionId  String?       @map("guest_session_id")
  guestSession    GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  userType        String?       @default("customer")
  adminUserId     String?
  adminUser       AdminUser?    @relation(fields: [adminUserId], references: [id])
  status          OrderStatus   @default(PENDING)
  totalAmount     Decimal       @db.Decimal(12, 2)
  subtotal        Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @db.Decimal(12, 2) @default(0)
  shippingCharge  Decimal       @db.Decimal(12, 2) @default(0)
  version         Int           @default(0)
  taxAmount       Decimal       @db.Decimal(12, 2) @default(0)
  shippingAddress Json?
  paymentMethod   String?
  paymentStatus   PaymentStatus @default(PENDING)
  channel         String        @default("online")
  couponId        String?
  notes           String?
  cancelledAt     DateTime?
  deliveredAt     DateTime?

  storeId String?
  store   StoreLocation? @relation(fields: [storeId], references: [id])

  items          OrderItem[]
  statusLogs     OrderStatusLog[]
  payments       Payment[]
  invoices       Invoice[]
  shippingAddresses ShippingAddress[]
  courierReceipts   CourierReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([guestSessionId])
  @@index([status])
  @@index([storeId])
  @@index([orderNumber])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([guestSessionId, createdAt])
  @@index([adminUserId])
  @@map("orders")
}

model OrderStatusLog {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String   @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String?  @map("changed_by")
  note       String?  @map("note")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([orderId, createdAt])
  @@map("order_status_logs")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)
  unitId    String?
  type      String  @default("sale")
  hsnCode   String?
  taxRate   Decimal? @db.Decimal(5, 2)
  cgstAmount  Decimal? @db.Decimal(12, 2)
  sgstAmount  Decimal? @db.Decimal(12, 2)
  igstAmount  Decimal? @db.Decimal(12, 2)
  depositAmount Decimal? @db.Decimal(12, 2)
  rentStart   DateTime?
  rentEnd     DateTime?
  rentDays    Int?
  status      String  @default("confirmed")

  rentalBookings RentalBooking[]
  reviews        Review[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model Cart {
  id      String   @id @default(uuid())
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int      @default(1)
  type      String   @default("sale")
  rentStart DateTime?
  rentEnd   DateTime?

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

// ══════════════════════════════════════════════════════════
//  SHIPPING
// ══════════════════════════════════════════════════════════

model ShippingAddress {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  name    String
  phone   String
  line1   String
  line2   String?
  city    String
  state   String
  pincode String
  country String @default("IND")

  @@index([orderId])
  @@map("shipping_addresses")
}

model CourierReceipt {
  id                String    @id @default(uuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id])
  courierName       String
  awbNumber         String
  trackingUrl       String?
  receiptFileUrl    String?
  source            String    @default("manual")
  enteredByAdminId  String?
  receivedBy        AdminUser? @relation("CourierEntry", fields: [enteredByAdminId], references: [id])
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([orderId])
  @@map("courier_receipts")
}

// ══════════════════════════════════════════════════════════
//  INVENTORY
// ══════════════════════════════════════════════════════════

model InventoryUnit {
  id             String  @id @default(uuid())
  variantId      String
  variant        ProductVariant @relation(fields: [variantId], references: [id])
  storeId        String
  store          StoreLocation @relation(fields: [storeId], references: [id])
  status         String  @default("available")
  conditionNotes String?

  rentalBookings RentalBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variantId, storeId])
  @@index([status])
  @@map("inventory_units")
}

model InventorySummary {
  variantId          String
  variant            ProductVariant @relation(fields: [variantId], references: [id])
  storeId            String
  store              StoreLocation @relation(fields: [storeId], references: [id])
  quantityAvailable  Int @default(0)
  quantityReserved   Int @default(0)
  quantityLocked     Int @default(0)
  quantitySold       Int @default(0)
  lowStockThreshold  Int @default(5)

  updatedAt DateTime @updatedAt

  @@id([variantId, storeId])
  @@map("inventory_summary")
}

model InventoryLock {
  id              String    @id @default(uuid())
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  storeId         String
  store           StoreLocation @relation(fields: [storeId], references: [id])
  lockedByAdminId String?
  lockedBy        AdminUser? @relation(fields: [lockedByAdminId], references: [id])
  deviceId        String?
  clientUuid      String
  reason          String?
  quantity        Int       @default(1)
  orderId         String?   @map("order_id")
  status          String    @default("active")
  lockedAt        DateTime  @default(now())
  expiresAt       DateTime
  releasedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([variantId, storeId, status])
  @@map("inventory_locks")
}

model StockMovement {
  id              String             @id @default(uuid())
  variantId       String
  variant         ProductVariant     @relation(fields: [variantId], references: [id])
  storeId         String
  store           StoreLocation      @relation(fields: [storeId], references: [id])
  quantityChange  Int
  type            StockMovementType
  reference       String?
  notes           String?
  createdByAdminId String?
  createdBy       AdminUser?         @relation(fields: [createdByAdminId], references: [id])

  createdAt DateTime @default(now())

  @@index([variantId, storeId, createdAt])
  @@index([type])
  @@index([createdByAdminId])
  @@index([reference])
  @@map("stock_movements")
}

// ══════════════════════════════════════════════════════════
//  PAYMENTS
// ══════════════════════════════════════════════════════════

model Payment {
  id                      String    @id @default(uuid())
  orderId                 String
  order                   Order     @relation(fields: [orderId], references: [id])
  razorpayOrderId          String?
  razorpayPaymentId        String?
  razorpayEventId          String?
  razorpayPreAuthId String?
  preAuthStatus     String?
  amount                  Decimal   @db.Decimal(12, 2)
  currency                String    @default("INR")
  type                    PaymentType
  method                  PaymentMethod?
  channel                 PaymentChannel @default(ONLINE)
  status                  PaymentStatus @default(PENDING)
  offlineReceivedByAdminId String?
  offlineReceivedBy        AdminUser? @relation("OfflinePaymentReceiver", fields: [offlineReceivedByAdminId], references: [id])
  offlineReference         String?
  metadata                Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([orderId])
  @@index([razorpayPaymentId])
  @@map("payments")
}

// ══════════════════════════════════════════════════════════
//  RENTALS
// ══════════════════════════════════════════════════════════

model RentalBooking {
  id                  String              @id @default(uuid())
  orderItemId         String
  orderItem           OrderItem           @relation(fields: [orderItemId], references: [id])
  unitId              String
  unit                InventoryUnit       @relation(fields: [unitId], references: [id])
  storeId             String
  store               StoreLocation       @relation(fields: [storeId], references: [id])
  status              RentalBookingStatus @default(BOOKED)
  bookedAt            DateTime            @default(now())
  pickupAt            DateTime?
  dueReturnAt         DateTime
  bookingPeriod       Unsupported("tstzrange")? @map("booking_period")
  actualReturnAt      DateTime?
  inspectedAt         DateTime?
  inspectedByAdminId   String?
  inspectedBy          AdminUser?          @relation("RentalInspector", fields: [inspectedByAdminId], references: [id])
  depositAmount       Decimal             @db.Decimal(12, 2)
  depositStatus       String              @default("collected")
  razorpayPreAuthId String?
  preAuthStatus     String?
  lateFee             Decimal             @db.Decimal(12, 2) @default(0)
  damageCharge        Decimal             @db.Decimal(12, 2) @default(0)
  damageNotes         String?
  damagePhotos        String[]
  closeNotes          String?

  extensions RentalExtension[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
  @@index([status])
  @@map("rental_bookings")
}

model RentalExtension {
  id                String   @id @default(uuid())
  rentalBookingId   String
  rentalBooking     RentalBooking @relation(fields: [rentalBookingId], references: [id])
  originalDueDate   DateTime
  newDueDate        DateTime
  additionalCharge  Decimal  @db.Decimal(12, 2)
  paymentId         String?
  approvedByAdminId String?
  approvedBy        AdminUser? @relation("ExtensionApprover", fields: [approvedByAdminId], references: [id])
  createdAt         DateTime @default(now())

  @@index([rentalBookingId])
  @@map("rental_extensions")
}

// ══════════════════════════════════════════════════════════
//  INVOICING
// ══════════════════════════════════════════════════════════

model InvoiceSequence {
  storeId       String
  financialYear String
  lastNumber    Int @default(0)

  @@id([storeId, financialYear])
  @@map("invoice_sequences")
}

model Invoice {
  id              String      @id @default(uuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id])
  invoiceNumber   String      @unique
  storeId         String
  store           StoreLocation @relation(fields: [storeId], references: [id])
  financialYear   String
  type            InvoiceType @default(INVOICE)
  parentInvoiceId String?
  parentInvoice   Invoice?    @relation("InvoiceCreditNote", fields: [parentInvoiceId], references: [id])
  childInvoices   Invoice[]   @relation("InvoiceCreditNote")
  pdfUrl          String
  pdfStorageKey   String?
  taxableValue    Decimal     @db.Decimal(12, 2)
  cgst            Decimal     @db.Decimal(12, 2) @default(0)
  sgst            Decimal     @db.Decimal(12, 2) @default(0)
  igst            Decimal     @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal     @db.Decimal(12, 2)
  amountInWords   String?
  billingName     String
  billingAddress  String
  billingGstin    String?
  billingState    String
  shippingState   String?
  eInvoiceIrn     String?
  eInvoiceAckDate DateTime?
  eInvoiceStatus  String?
  createdAt       DateTime    @default(now())

  @@index([orderId])
  @@index([invoiceNumber])
  @@index([storeId, financialYear])
  @@map("invoices")
}

// ══════════════════════════════════════════════════════════
//  ADMIN & RBAC
// ══════════════════════════════════════════════════════════

model RoleModel {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  isSystem      Boolean  @default(false)
  createdByAdminId String?
  createdBy     AdminUser? @relation("RoleCreator", fields: [createdByAdminId], references: [id])

  adminUsers      AdminUser[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now())

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  module      String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         RoleModel   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AdminUser {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  roleId       String
  role         RoleModel @relation(fields: [roleId], references: [id])
  storeIds     String[]
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  deletedAt    DateTime?

  createdRoles      RoleModel[]       @relation("RoleCreator")
  inventoryLocks    InventoryLock[]
  reviewedReviews   Review[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  offlinePayments   Payment[]        @relation("OfflinePaymentReceiver")
  stockMovements    StockMovement[]
  inspectedRentals  RentalBooking[]  @relation("RentalInspector")
  approvedExtensions RentalExtension[] @relation("ExtensionApprover")
  courierReceipts   CourierReceipt[]   @relation("CourierEntry")
  inquiries         Inquiry[]          @relation("InquiryAssignee")
  orders            Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([deletedAt])
  @@map("admin_users")
}

// ══════════════════════════════════════════════════════════
//  AUDIT
// ══════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?
  admin      AdminUser? @relation(fields: [adminId], references: [id])
  action     String
  entity     String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════════
//  ENGAGEMENT — Wishlist, Notifications, Inquiries
// ══════════════════════════════════════════════════════════

model Wishlist {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId         String
  variant           ProductVariant @relation(fields: [variantId], references: [id])
  notifyOnRestock   Boolean  @default(false)
  notifyOnPriceDrop Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@unique([userId, variantId])
  @@map("wishlists")
}

// ══════════════════════════════════════════════════════════
//  GUEST SESSION (common table for unauthenticated users)
// ══════════════════════════════════════════════════════════

model GuestSession {
  id              String   @id @default(uuid())
  expiresAt       DateTime
  lastActivityAt  DateTime @default(now())
  createdAt       DateTime @default(now())

  cartItems       GuestCartItem[]
  wishlistItems   GuestWishlistItem[]
  addresses       GuestAddress[]
  orders          Order[]
  reviews         Review[]

  @@index([expiresAt])
  @@index([lastActivityAt])
  @@map("guest_sessions")
}

model GuestCartItem {
  id              String        @id @default(uuid())
  guestSessionId  String        @map("guest_session_id")
  guestSession    GuestSession  @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  quantity        Int           @default(1)
  type            String        @default("sale")
  rentStart       DateTime?
  rentEnd         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([guestSessionId, variantId, type])
  @@index([guestSessionId])
  @@map("guest_cart_items")
}

model GuestWishlistItem {
  id                String   @id @default(uuid())
  guestSessionId    String   @map("guest_session_id")
  guestSession      GuestSession @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  variantId         String
  variant           ProductVariant @relation(fields: [variantId], references: [id])
  notifyOnRestock   Boolean  @default(false)
  notifyOnPriceDrop Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@unique([guestSessionId, variantId])
  @@index([guestSessionId])
  @@map("guest_wishlist_items")
}

// ══════════════════════════════════════════════════════════
//  GUEST ADDRESS
// ══════════════════════════════════════════════════════════

model GuestAddress {
  id              String        @id @default(uuid())
  guestSessionId  String        @map("guest_session_id")
  guestSession    GuestSession  @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)

  label           String
  fullName        String
  phone           String
  addressLine1    String
  addressLine2    String?
  city            String
  state           String
  postalCode      String
  country         String        @default("India")
  isDefault       Boolean       @default(false)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([guestSessionId])
  @@map("guest_addresses")
}

model Notification {
  id         String               @id @default(uuid())
  userId     String?
  user       User?                @relation(fields: [userId], references: [id])
  adminId    String?
  type       String
  channel    NotificationChannel
  title      String?
  body       String?
  dataJson   Json?
  status     NotificationStatus   @default(PENDING)
  sentAt     DateTime?
  failedReason String?
  createdAt  DateTime             @default(now())

  @@index([userId, status])
  @@map("notifications")
}

model Inquiry {
  id              String        @id @default(uuid())
  name            String
  email           String?
  phone           String?
  message         String
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id])
  status          InquiryStatus @default(NEW)
  assignedAdminId String?
  assignedAdmin   AdminUser?    @relation("InquiryAssignee", fields: [assignedAdminId], references: [id])
  resolutionNotes String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("inquiries")
}

// ══════════════════════════════════════════════════════════
//  COUPONS
// ══════════════════════════════════════════════════════════

model Coupon {
  id              String         @id @default(uuid())
  code            String         @unique
  description     String?
  type            CouponType
  value           Decimal        @db.Decimal(12, 2)
  minCartValue    Decimal        @db.Decimal(12, 2) @default(0)
  maxDiscount     Decimal?       @db.Decimal(12, 2)
  appliesTo       CouponAppliesTo @default(ALL)
  categoryIds     String[]
  brandIds        String[]
  usageLimit      Int?
  usedCount       Int            @default(0)
  perUserLimit    Int            @default(1)
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean        @default(true)
  createdByAdminId String?
  createdAt       DateTime       @default(now())

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id           String   @id @default(uuid())
  couponId     String
  coupon       Coupon   @relation(fields: [couponId], references: [id])
  userId       String?
  orderId      String
  discountGiven Decimal @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  @@index([couponId])
  @@map("coupon_usages")
}

// ══════════════════════════════════════════════════════════
//  POS & WALLET
// ══════════════════════════════════════════════════════════

model PosDevice {
  id               String    @id @default(uuid())
  storeId          String
  deviceName       String
  deviceUuid       String    @unique
  apiKeyHash       String
  isActive         Boolean   @default(true)
  lastSyncedAt     DateTime?
  lastIp           String?
  pendingOutboxCount Int     @default(0)
  registeredByAdminId String?
  registeredAt     DateTime  @default(now())

  @@map("pos_devices")
}

model WalletTransaction {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Decimal  @db.Decimal(12, 2)
  type          String
  referenceId   String?
  referenceType String?
  balanceAfter  Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("wallet_transactions")
}

// ══════════════════════════════════════════════════════════
//  STOCK AUDIT
// ══════════════════════════════════════════════════════════

model StockAudit {
  id                String    @id @default(uuid())
  storeId           String
  variantId         String
  systemQty         Int
  physicalQty       Int
  difference        Int
  reason            String?
  status            String    @default("pending")
  conductedByAdminId String
  approvedByAdminId  String?
  conductedAt       DateTime  @default(now())
  approvedAt        DateTime?

  @@map("stock_audits")
}

// ══════════════════════════════════════════════════════════
//  FEATURE FLAGS & RETURN POLICIES
// ══════════════════════════════════════════════════════════

model FeatureFlag {
  key             String    @id
  isEnabled       Boolean   @default(false)
  configJson      Json?
  updatedByAdminId String?
  updatedAt       DateTime  @updatedAt

  @@map("feature_flags")
}

model ReturnPolicy {
  id                String   @id @default(uuid())
  type              String   @unique
  windowDays        Int?
  penaltyPercent    Decimal? @db.Decimal(5, 2)
  description       String?
  isActive          Boolean  @default(true)
  updatedByAdminId  String?
  updatedAt         DateTime @updatedAt

  @@map("return_policies")
}

// ══════════════════════════════════════════════════════════
//  REPORTS & EXPORTS
// ══════════════════════════════════════════════════════════

model ReportExport {
  id                String       @id @default(uuid())
  requestedByAdminId String
  reportType        String
  format            String
  parameters        Json?
  fileUrl           String?
  status            ReportStatus @default(PROCESSING)
  errorMessage      String?
  createdAt         DateTime     @default(now())
  completedAt       DateTime?

  @@map("reports_exports")
}
